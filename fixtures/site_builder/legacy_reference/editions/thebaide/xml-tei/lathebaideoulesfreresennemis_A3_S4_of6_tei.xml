    </sp>
    <sp>
      <speaker>ETEOCLE.</speaker>
<l n="843">
Et 
      <app>
        <lem wit="#A #B #D #E">quoy </lem>
        <rdg wit="#C">quoi </rdg>
      </app>

      <app>
        <lem wit="#A #B #E">mesme </lem>
        <rdg wit="#C #D">même </rdg>
      </app>

      <app>
        <lem wit="#A #B #E">Creon </lem>
        <rdg wit="#C #D">Créon </rdg>
      </app>
pour la Paix se declare&#160;? </l>

    </sp>
    <sp>
      <speaker>CREON.</speaker>
<l n="844">
Pour avoir trop aimé cette guerre barbare, </l>

<l n="845">
Vous 
      <app>
        <lem wit="#A #B #E">voyez </lem>
        <rdg wit="#C">voiés </rdg>
        <rdg wit="#D">voïez </rdg>
      </app>
les 
      <app>
        <lem wit="#A #B #E">malheurs </lem>
        <rdg wit="#C #D">mal-heurs </rdg>
      </app>

      <app>
        <lem wit="#A #E">ou </lem>
        <rdg wit="#B #C #D">où </rdg>
      </app>
le Ciel m’a 
      <app>
        <lem wit="#A #E">plongé, </lem>
        <rdg wit="#B #C #D">plongé. </rdg>
      </app>
</l>

<l n="846.1">
Mon Fils est mort, Seigneur. </l>
