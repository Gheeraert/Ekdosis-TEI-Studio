        <rdg wit="#C">Laissés&#160;couler </rdg>
        <rdg wit="#D">Laissez&#160;couler </rdg>
      </app>
son sang sans y 
      <app>
        <lem wit="#A #B #E">joindre </lem>
        <rdg wit="#C #D">mesler </rdg>
      </app>
le 
      <app>
        <lem wit="#A #B #E">vostre, </lem>
        <rdg wit="#C #D">vôtre, </rdg>
      </app>
