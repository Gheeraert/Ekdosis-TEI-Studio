       </lem>
       <rdg wit="#A">
        Ie
       </rdg>
      </app>
      veux pleurer,
      <app>
       <lem wit="#A #B #E">
        Creon,
       </lem>
       <rdg wit="#C #D">
        Créon,
       </rdg>
      </app>
      &amp; vous
      <app>
       <lem wit="#A #B #D #E">
        voulez
       </lem>
       <rdg wit="#C">
        voulés
       </rdg>
      </app>
      regner.
     </l>
    </sp>
    <sp>
     <speaker>
      CREON, arrestant Antigone.
     </speaker>
     <l n="1545">
      Ah&#160;! Madame,
      <app>
       <lem wit="#A #B #D #E">
