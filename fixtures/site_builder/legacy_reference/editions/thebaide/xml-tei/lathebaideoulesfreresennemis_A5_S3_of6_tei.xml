       </lem>
       <rdg wit="#C">
        regnés
       </rdg>
      </app>
      &amp;
      <app>
       <lem wit="#A #B #D #E">
        montez
       </lem>
       <rdg wit="#C">
        montés
       </rdg>
      </app>
      sur le
      <app>
       <lem wit="#A #B #E">
        Trosne,
       </lem>
       <rdg wit="#C #D">
        Trône,
       </rdg>
      </app>
     </l>
     <l n="1546">
      Ce haut rang
      <app>
       <lem wit="#A #E">
        n’apartient
       </lem>
       <rdg wit="#B #C #D">
        n’appartient
       </rdg>
      </app>
      qu’à l’illustre Antigone.
     </l>
    </sp>
    <sp>
     <speaker>
      ANTIGONE.
     </speaker>
     <l n="1547">
      Il me tarde déja que vous ne
      <app>
       <lem wit="#A #D #E">
        l’occupiez,
       </lem>
       <rdg wit="#B">
        l’occupiez.
       </rdg>
       <rdg wit="#C">
        l’occupiés.
       </rdg>
      </app>
     </l>
     <l n="1548.1">
      La Couronne est à vous.
     </l>
    </sp>
    <sp>
     <speaker>
      CREON.
     </speaker>
     <l n="1548.2">
      Je la mets à vos
      <app>
       <lem wit="#A #E">
        pieds.
       </lem>
       <rdg wit="#B">
        piez.
       </rdg>
       <rdg wit="#C #D">
        piés.
       </rdg>
      </app>
     </l>
    </sp>
    <sp>
     <speaker>
      ANTIGONE.
     </speaker>
     <l n="1549">
      Je la refuserois de la main des Dieux
      <app>
       <lem wit="#A #B #E">
        mesme,
       </lem>
       <rdg wit="#C #D">
        même,
       </rdg>
      </app>
     </l>
     <l n="1550">
      Et vous
      <app>
       <lem wit="#A #B #D #E">
        osez,
       </lem>
       <rdg wit="#C">
        osés,
       </rdg>
      </app>
      <app>
       <lem wit="#A #B #E">
        Creon,
       </lem>
       <rdg wit="#C #D">
        Créon,
       </rdg>
      </app>
      m’offrir le
      <app>
       <lem wit="#A #E">
        Diadéme.
       </lem>
       <rdg wit="#B">
        Diadéme&#160;?
       </rdg>
       <rdg wit="#C #D">
        Diadême&#160;?
       </rdg>
      </app>
     </l>
    </sp>
    <sp>
     <speaker>
      CREON.
     </speaker>
     <l n="1551">
      Je
      <app>
       <lem wit="#A #B #D #E">
        sçay
       </lem>
       <rdg wit="#C">
        sçai
       </rdg>
      </app>
      que ce haut rang n’a rien de glorieux,
     </l>
     <l n="1552">
      Qui ne cede à l’honneur de l’offrir à vos yeux.
     </l>
     <l n="1553">
      D’un si noble destin je me connois
      <app>
       <lem wit="#A #E">
        indigne,
       </lem>
       <rdg wit="#B #C #D">
        indigne.
       </rdg>
      </app>
     </l>
     <l n="1554">
      Mais si l’on peut pretendre à cette gloire insigne,
     </l>
     <l n="1555">
      Si par d’illustres faits on la peut meriter,
     </l>
     <l n="1556.1">
      Que faut-il faire enfin, Madame&#160;?
     </l>
    </sp>
    <sp>
     <speaker>
      ANTIGONE.
     </speaker>
     <l n="1556.2">
      M’imiter.
     </l>
    </sp>
    <sp>
     <speaker>
      CREON.
     </speaker>
     <l n="1557">
      Que ne
      <app>
       <lem wit="#B #C #D #E">
        ferois-je
       </lem>
       <rdg wit="#A">
        ferois-ie
       </rdg>
      </app>
      point pour une telle
      <app>
       <lem wit="#A #E">
        grace,
       </lem>
       <rdg wit="#B #C #D">
        grace&#160;!
       </rdg>
      </app>
     </l>
     <l n="1558">
      <app>
       <lem wit="#A #B #D #E">
        Ordonnez
       </lem>
       <rdg wit="#C">
        Ordonnés
       </rdg>
      </app>
      seulement ce qu’il faut que
      <app>
       <lem wit="#B #C #D #E">
        je
       </lem>
       <rdg wit="#A">
        ie
       </rdg>
      </app>
      fasse,
     </l>
     <l n="1559.1">
      <app>
       <lem wit="#B #C #D #E">
        Je
       </lem>
       <rdg wit="#A">
        Ie
       </rdg>
      </app>
      suis prest…
     </l>
    </sp>
    <sp>
     <speaker>
      ANTIGONE
     </speaker>
     <l n="1559.2">
